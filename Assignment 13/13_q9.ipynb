        "import numpy as np\n",
        "\n",
        "arr = np.random.randint(1,51,20)\n",
        "\n",
        "matrix = arr.reshape(4,5)\n",
        "\n",
        "print(matrix)\n",
        "\n",
        "print(\"Sum =\", matrix.sum())\n",
        "print(\"Mean =\", matrix.mean())\n",
        "print(\"Standard Deviation =\", matrix.std())\n",
        "\n",
        "print(\"Maximum in each row\")\n",
        "print(matrix.max(axis=1))"
