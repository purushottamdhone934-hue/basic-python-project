        "import numpy as np\n",
        "\n",
        "v1 = np.array([2,4,6,8])\n",
        "v2 = np.array([1,3,5,7])\n",
        "\n",
        "print(\"Addition\")\n",
        "print(v1+v2)\n",
        "\n",
        "print(\"Subtraction\")\n",
        "print(v1-v2)\n",
        "\n",
        "print(\"Element-wise Multiplication\")\n",
        "print(v1*v2)\n",
        "\n",
        "print(\"Dot Product\")\n",
        "print(np.dot(v1,v2))"
      ],
